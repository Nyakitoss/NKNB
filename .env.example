# Telegram Bot Configuration
API_ID=your_api_id
API_HASH=your_api_hash
NEWS_BOT_TOKEN=your_bot_token

# AI Provider Configuration
AI_PROVIDER=groq  # Options: gemini, groq

# API Keys (add at least one)
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Redis Configuration (for Railway)
USE_REDIS=true
REDIS_HOST=your-redis-host.railway.app
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Local Development (set USE_REDIS=false)
# USE_REDIS=false
