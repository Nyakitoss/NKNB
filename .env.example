# Telegram Bot Configuration
API_ID=your_api_id
API_HASH=your_api_hash
NEWS_BOT_TOKEN=your_bot_token

# AI Provider Configuration
AI_PROVIDER=openrouter  # Options: gemini, groq, grok, openrouter

# API Keys (add at least one)
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key
GROK_API_KEY=your_grok_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# News Sources Configuration (edit these to change RSS feeds)
# Current sources: РБК, Коммерсантъ, Ведомости, TJournal, Habr, CNews, РИА Новости, Lenta.ru
# You can add/remove sources by editing news_parser.py

# Redis Configuration (for Railway)
USE_REDIS=true
REDIS_HOST=your-redis-host.railway.app
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Local Development (set USE_REDIS=false)
# USE_REDIS=false
